# Contact form email delivery (Resend — https://resend.com)
# 1. Sign up at resend.com and create an API key.
# 2. Copy this file to `.env.local` and paste your key below.
# The `onboarding@resend.dev` sender works out of the box for testing.
# To send from your own domain, verify it in Resend and set CONTACT_FROM_EMAIL.
RESEND_API_KEY=

# Optional overrides (sensible defaults are baked in):
# CONTACT_TO_EMAIL=zkashif.bscs21seecs@seecs.edu.pk
# CONTACT_FROM_EMAIL="Portfolio <onboarding@resend.dev>"
